{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/api/sessions",
    "bodyPatterns": [
      {
        "contains": "\"username\":\"nonowner\""
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "accessToken": "nonowner-token-fixed",
      "refreshToken": "refresh-token"
    }
  }
}