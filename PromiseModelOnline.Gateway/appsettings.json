{
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/connect/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeadersCopy": "true" },
          { "ResponseHeadersCopy": "true" }
        ]
      },
      "hubs-route": {
        "ClusterId": "api-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      }
    },
    "Clusters": {
      "api-cluster": {
        "Destinations": {
          "api": {
            "Address": "https://promisemodelonline.api:8000/"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "https://promisemodelonline.auth:8060/"
          }
        }
      }
    }
  }
}