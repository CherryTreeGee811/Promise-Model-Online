# ==============================
#  PromiseModelOnline – Local Dev
#  Copy to .env and fill values.
# ==============================

# ASP.NET Core environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# OpenID Connect issuer (Auth server URL)
JWT__ISSUER=https://promisemodelonline.auth:8060

# Expected audience for access tokens
JWT__AUDIENCE=promisemodelonline.api

# Database usernames (non‑secret – passwords are in run/secrets/)
PMO_API_DB_USER=pmo_api
PMO_AUTH_DB_USER=pmo_auth

# IMPORTANT: All secret values (passwords, certificate password) must be
# placed as plain files in the run/secrets/ directory.
# Required files:
#   run/secrets/db_sa_password
#   run/secrets/db_api_password
#   run/secrets/db_auth_password
#   run/secrets/cert_password
# See README for detailed setup instructions.